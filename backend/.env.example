DATABASE_URL=postgresql://localhost:5432/datacenter_map
PORT=3001
NODE_ENV=development

# Required for issuing admin sessions (always keep secret)
JWT_SECRET=

# Optional legacy bootstrap: if admin_auth.password_hash is still NULL, login also accepts this.
# Prefer creating the password via /api/auth/setup-password (stored as bcrypt in the DB).
# ADMIN_PASSWORD=

# Optional: if set, POST /api/auth/setup-password must send setupToken with the same value (protects public first-time setup).
# ADMIN_SETUP_TOKEN=

# Optional Google Sign-In: OAuth 2.0 Web client ID (must match frontend VITE_GOOGLE_CLIENT_ID)
# GOOGLE_CLIENT_ID=

# Comma-separated Google account emails allowed to receive an admin JWT (required for Google sign-in to appear).
# ADMIN_GOOGLE_EMAILS=you@gmail.com

# Optional: comma-separated list of allowed browser origins (CORS).
# FRONTEND_ORIGIN=http://localhost:5173,https://your-app.example

# Optional: HTTPS origin of the deployed SPA (first value used for links in emails)
# PUBLIC_APP_URL=https://your-app.vercel.app

# Tier E — public suggestions: notify admins via Resend (https://resend.com)
# RESEND_API_KEY=re_xxxx
# RESEND_FROM_EMAIL=onboarding@resend.dev
# ADMIN_NOTIFY_EMAIL=you@example.com,teammate@example.com
