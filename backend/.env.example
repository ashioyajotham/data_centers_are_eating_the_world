DATABASE_URL=postgresql://localhost:5432/datacenter_map
PORT=3001
NODE_ENV=development

# Required for admin login and for POST/PUT/PATCH/DELETE on /api/datacenters
# Use a long random value for each in production.
ADMIN_PASSWORD=
JWT_SECRET=

# Optional: comma-separated list of allowed browser origins (CORS).
# Defaults to http://localhost:5173 and http://127.0.0.1:5173 if unset.
# FRONTEND_ORIGIN=http://localhost:5173,https://your-app.example

# Optional: JWT lifetime (see jsonwebtoken / ms format), default 8h
# JWT_EXPIRES_IN=8h
